{
  "openapi": "3.0.3",
  "info": {
    "title": "MyWallet Frontend Storage Vision",
    "version": "0.2.0",
    "description": "Swagger-style contract for the planned localStorage structure. Storage is grouped into main stores for income, history/analysis, and items, using versioned envelopes for scalability."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local backend (planned)"
    }
  ],
  "paths": {},
  "components": {
    "schemas": {
      "LocalStorageSnapshot": {
        "type": "object",
        "description": "Deserialized view of localStorage keys used by the frontend.",
        "properties": {
          "lvf_income_store": {
            "$ref": "#/components/schemas/IncomeStore",
            "description": "Income config and income calculations."
          },
          "lvf_history_store": {
            "$ref": "#/components/schemas/HistoryStore",
            "description": "All historical data and analysis."
          },
          "lvf_items_store": {
            "$ref": "#/components/schemas/ItemsStore",
            "description": "Items for current month and per-month archives."
          },
          "access_token": {
            "type": "string",
            "description": "JWT access token stored as raw string under localStorage key access_token."
          },
          "refresh_token": {
            "type": "string",
            "description": "JWT refresh token stored as raw string under localStorage key refresh_token."
          },
          "user": {
            "allOf": [
              {
                "$ref": "#/components/schemas/User"
              }
            ],
            "description": "User profile stored as JSON string under localStorage key user."
          },
          "is_guest": {
            "type": "boolean",
            "description": "Guest mode flag stored as string 'true' under localStorage key is_guest."
          },
          "offline_sync_queue_v1": {
            "$ref": "#/components/schemas/SyncQueue",
            "description": "Offline sync queue stored as JSON string under localStorage key offline_sync_queue_v1."
          },
          "app-theme-preference": {
            "$ref": "#/components/schemas/ThemePreference",
            "description": "Theme preference stored as string under localStorage key app-theme-preference (only when not system)."
          }
        }
      },
      "IncomeStore": {
        "type": "object",
        "properties": {
          "version": { "type": "integer" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "data": { "$ref": "#/components/schemas/IncomeData" }
        },
        "required": ["version", "updatedAt", "data"]
      },
      "HistoryStore": {
        "type": "object",
        "properties": {
          "version": { "type": "integer" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "data": { "$ref": "#/components/schemas/HistoryData" }
        },
        "required": ["version", "updatedAt", "data"]
      },
      "ItemsStore": {
        "type": "object",
        "properties": {
          "version": { "type": "integer" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "data": { "$ref": "#/components/schemas/ItemsData" }
        },
        "required": ["version", "updatedAt", "data"]
      },
      "IncomeData": {
        "type": "object",
        "properties": {
          "incomeConfig": { "$ref": "#/components/schemas/UserIncomeConfig" },
          "sources": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MonthlyIncome" }
          },
          "taxProfile": { "$ref": "#/components/schemas/TaxProfile" },
          "savingsGoal": { "$ref": "#/components/schemas/SavingsGoal" },
          "calculation": { "$ref": "#/components/schemas/IncomeCalculation" }
        },
        "required": ["incomeConfig"]
      },
      "HistoryData": {
        "type": "object",
        "properties": {
          "budgetHistory": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BudgetHistory" }
          },
          "savingsHistory": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MonthlyRecord" }
          },
          "savingsSummary": { "$ref": "#/components/schemas/SavingsSummary" },
          "analysis": { "$ref": "#/components/schemas/HistoryAnalysis" }
        }
      },
      "ItemsData": {
        "type": "object",
        "properties": {
          "currentMonth": { "$ref": "#/components/schemas/MonthlyItems" },
          "months": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/MonthlyItems" }
          }
        },
        "required": ["currentMonth", "months"]
      },
      "MonthlyItems": {
        "type": "object",
        "properties": {
          "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ExpenseItem" }
          },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["month", "items", "updatedAt"]
      },
      "TaxProfile": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["fixed", "percentage", "progressive"]
          },
          "percentage": { "type": "number" },
          "fixedAmount": { "type": "number" },
          "brackets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TaxBracket" }
          }
        },
        "required": ["mode"]
      },
      "TaxBracket": {
        "type": "object",
        "properties": {
          "upTo": { "type": "number" },
          "rate": { "type": "number" }
        },
        "required": ["upTo", "rate"]
      },
      "SavingsGoal": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "type": { "type": "string", "enum": ["fixed", "percent_of_income"] },
          "target": { "type": "number" }
        },
        "required": ["enabled", "type", "target"]
      },
      "IncomeCalculation": {
        "type": "object",
        "properties": {
          "grossMonthlyIncome": { "type": "number" },
          "estimatedTaxes": { "type": "number" },
          "netMonthlyIncome": { "type": "number" },
          "effectiveHourlyRate": { "type": "number" },
          "lastCalculatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "SavingsSummary": {
        "type": "object",
        "properties": {
          "totalSavings": { "type": "number" },
          "manualSavingsLog": { "type": "number" },
          "lastUpdated": { "type": "string", "format": "date-time" }
        }
      },
      "HistoryAnalysis": {
        "type": "object",
        "properties": {
          "monthsCount": { "type": "integer" },
          "totalIncome": { "type": "number" },
          "totalExpenses": { "type": "number" },
          "totalSavings": { "type": "number" },
          "averageSavingsRate": { "type": "number" },
          "lastUpdated": { "type": "string", "format": "date-time" }
        }
      },
      "MonthlyIncome": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "amount": { "type": "number" },
          "isRecurring": { "type": "boolean" },
          "frequency": {
            "type": "string",
            "enum": ["daily", "weekly", "bi-weekly", "monthly", "yearly"]
          }
        },
        "required": ["id", "source", "amount", "isRecurring", "frequency"]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        },
        "required": ["id", "username", "email"]
      },
      "UserIncomeConfig": {
        "type": "object",
        "properties": {
          "monthlyIncome": { "type": "number" },
          "workHoursPerMonth": { "type": "number" },
          "hourlyRate": { "type": "number" },
          "isHourlyManual": { "type": "boolean" },
          "calculationMethod": {
            "type": "string",
            "enum": ["weekly", "manual"]
          },
          "weeklyHoursDetails": {
            "type": "object",
            "properties": {
              "hoursPerDay": { "type": "number" },
              "daysPerWeek": { "type": "number" }
            },
            "required": ["hoursPerDay", "daysPerWeek"]
          }
        },
        "required": ["monthlyIncome", "isHourlyManual"]
      },
      "ExpenseItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "name": { "type": "string" },
          "amount": { "type": "number" },
          "unitPrice": { "type": "number" },
          "quantity": { "type": "number" },
          "isIgnored": { "type": "boolean" },
          "type": {
            "type": "string",
            "enum": ["Responsibility", "Burning", "Saving"]
          },
          "priority": {
            "type": "string",
            "enum": ["Must Have", "Want", "Emergency", "Gift"]
          }
        },
        "required": ["id", "name", "amount", "unitPrice", "quantity", "type", "priority"]
      },
      "BudgetHistory": {
        "type": "object",
        "properties": {
          "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
          "date": { "type": "string", "format": "date-time" },
          "incomeConfig": { "$ref": "#/components/schemas/UserIncomeConfig" },
          "expenses": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ExpenseItem" }
          },
          "summary": { "$ref": "#/components/schemas/BudgetSummary" }
        },
        "required": ["month", "date", "incomeConfig", "expenses", "summary"]
      },
      "BudgetSummary": {
        "type": "object",
        "properties": {
          "totalIncome": { "type": "number" },
          "totalExpenses": { "type": "number" },
          "remainingIncome": { "type": "number" },
          "hourlyRate": { "type": "number" },
          "savingsRate": { "type": "number" }
        },
        "required": ["totalIncome", "totalExpenses", "remainingIncome", "hourlyRate", "savingsRate"]
      },
      "MonthlyRecord": {
        "type": "object",
        "properties": {
          "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
          "income": { "type": "number" },
          "expenses": { "type": "number" },
          "freeMoney": { "type": "number" },
          "transferredToSavings": { "type": "number" },
          "plannedSavings": { "type": "number" },
          "savingsImpact": { "type": "number" },
          "manualAdded": { "type": "number" },
          "savingsTotalAfterTransfer": { "type": "number" },
          "date": { "type": "string", "format": "date-time" }
        },
        "required": [
          "month",
          "income",
          "expenses",
          "freeMoney",
          "transferredToSavings",
          "plannedSavings",
          "savingsImpact",
          "savingsTotalAfterTransfer",
          "date"
        ]
      },
      "SyncOp": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "payload": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "type", "payload", "createdAt"]
      },
      "SyncQueue": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/SyncOp" }
      },
      "ThemePreference": {
        "type": "string",
        "enum": ["light", "dark", "system"],
        "description": "Only light/dark are persisted; system means no stored key."
      }
    }
  }
}
